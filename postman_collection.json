{
  "info": {
    "name": "BackendAssignment",
    "description": "API key manager + job queue",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "api_key",
      "value": "",
      "description": "paste raw_key here after creating one"
    },
    {
      "key": "key_id",
      "value": ""
    },
    {
      "key": "job_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "health check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        }
      }
    },
    {
      "name": "create api key",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var res = pm.response.json();",
              "if (res.raw_key) {",
              "    pm.collectionVariables.set('api_key', res.raw_key);",
              "    pm.collectionVariables.set('key_id', res.id);",
              "    console.log('saved key:', res.raw_key);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"test-app\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/keys/",
          "host": ["{{base_url}}"],
          "path": ["keys", ""]
        },
        "description": "raw_key is auto-saved to collection variable by the test script"
      }
    },
    {
      "name": "list keys",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/keys/",
          "host": ["{{base_url}}"],
          "path": ["keys", ""]
        }
      }
    },
    {
      "name": "submit job (with key)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var res = pm.response.json();",
              "if (res.id) {",
              "    pm.collectionVariables.set('job_id', res.id);",
              "    console.log('job id:', res.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{api_key}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payload\": \"process this thing\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/submit-job",
          "host": ["{{base_url}}"],
          "path": ["submit-job"]
        }
      }
    },
    {
      "name": "submit job (no key - should 401)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payload\": \"this should fail\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/submit-job",
          "host": ["{{base_url}}"],
          "path": ["submit-job"]
        }
      }
    },
    {
      "name": "get job status",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/job/{{job_id}}",
          "host": ["{{base_url}}"],
          "path": ["job", "{{job_id}}"]
        },
        "description": "wait ~3 seconds after submitting, then check this"
      }
    },
    {
      "name": "revoke key",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{base_url}}/keys/{{key_id}}",
          "host": ["{{base_url}}"],
          "path": ["keys", "{{key_id}}"]
        }
      }
    }
  ]
}
